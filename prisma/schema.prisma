generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// NextAuth.js (https://next-auth.js.org/adapters/prisma)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  /// 표시용 닉네임. 비어 있으면 OAuth name → 이메일 @ 앞부분 순으로 표시
  nickname      String?
  /// 프로필 이미지 대신 표시할 이모지. 비어 있으면 기본(🏃)
  profileEmoji  String?
  /// 이번 주(월~일) 거리 목표(km), 미설정 시 null
  weeklyDistanceGoalKm  Decimal? @db.Decimal(8, 2)
  /// 이번 달 거리 목표(km), 미설정 시 null
  monthlyDistanceGoalKm Decimal? @db.Decimal(8, 2)
  accounts       Account[]
  sessions       Session[]
  runs              Run[]
  communityPosts    CommunityPost[]
  communityComments CommunityComment[]
  communityReactions CommunityPostReaction[]
  badges            UserBadge[]
}

/// 조건 달성 시 1회 저장(획득 시각 보존). 기록 삭제로 회수하지 않음
model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String   @db.VarChar(48)
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Run {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  distanceKm     Decimal  @db.Decimal(8, 2)
  durationSec    Int
  /// 세션 평균 심박수 (bpm), 선택
  avgHeartRate Int?
  /// 러닝 케이던스 (걸음/분 spm), 선택
  cadence      Int?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  communityPosts CommunityPost[]

  @@index([userId, date(sort: Desc)])
}

/// 기간형 챌린지(이번 주·이번 달 등). slug로 idempotent 생성
model Challenge {
  id        String          @id @default(cuid())
  slug      String          @unique
  title     String
  summary   String?
  startsAt  DateTime
  endsAt    DateTime
  posts     CommunityPost[]

  @@index([endsAt])
}

/// 커뮤니티 한 줄 후기. 커뮤니티에서는 닉네임만 노출(별도 헬퍼)
model CommunityPost {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String?
  challenge   Challenge? @relation(fields: [challengeId], references: [id], onDelete: SetNull)
  runId       String?
  run         Run?       @relation(fields: [runId], references: [id], onDelete: SetNull)
  content     String     @db.VarChar(280)
  createdAt   DateTime   @default(now())
  comments    CommunityComment[]
  reactions   CommunityPostReaction[]

  @@index([createdAt(sort: Desc)])
  @@index([challengeId])
  @@index([userId])
}

/// 글에 달린 댓글 (짧게)
model CommunityComment {
  id        String        @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String        @db.VarChar(200)
  createdAt DateTime      @default(now())

  @@index([postId, createdAt])
  @@index([userId])
}

/// 글당 사용자 1개 반응 (프리셋 kind)
model CommunityPostReaction {
  postId    String
  userId    String
  kind      String        @db.VarChar(24)
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([postId])
}
