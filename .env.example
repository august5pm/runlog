# Supabase / PostgreSQL
# 런타임(Vercel): Transaction pooler URL + Prisma 권장 쿼리 파라미터
# connection_limit=1 권장 — 서버리스·로컬 dev에서 인스턴스당 연결 수를 줄여 DB max connections(예: 200) 고갈 방지
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# 마이그레이션(prisma migrate): Direct connection
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# NextAuth — https://next-auth.js.org/configuration/options
NEXTAUTH_URL="http://localhost:3000"
# openssl rand -base64 32
NEXTAUTH_SECRET=""

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# 기상청 단기예보 — 초단기실황 (공공데이터포털 https://www.data.go.kr/ 에서 발급)
# 마이페이지의 「일반 인증키 (Encoding)」 권장. 401이면 「Decoding」 키로 바꿔 보세요.
DATA_GO_KR_SERVICE_KEY=""
# 관측 위치: 위·경도(기본 서울 시청 부근) 또는 격자 nx/ny 직접 지정
WEATHER_LAT="37.5665"
WEATHER_LON="126.9780"
# WEATHER_GRID_NX=60
# WEATHER_GRID_NY=127
# UI에는 미표시(코드 호환용으로만 유지 가능)
WEATHER_LOCATION_LABEL="서울"
# 클릭 시 이동할 네이버 날씨 URL (기본값)
NAVER_WEATHER_URL="https://weather.naver.com/"
